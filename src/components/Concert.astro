---
import FormattedDate from './FormattedDate.astro';
import Song from './Song.astro';
import type { Concert } from '../types/concert';

export interface Props {
  concert: {
    id: string;
    data: Concert;
  };
  index: number;
}

const { concert, index } = Astro.props;
---
<>
  <tr class="transition hover:bg-gray-50">
    <td
      class="border-b border-gray-200 bg-gray-500 px-4 py-2 text-center font-mono text-3xl tracking-tight text-gray-50">
      {index + 1}
    </td>
    <td class="border-b border-gray-200 px-4 py-2 text-gray-700">
      <FormattedDate date={concert.data.date} />
    </td>
    <td class="border-b border-gray-200 px-4 py-2 text-gray-700">
      <span>{concert.data.venue.name}</span>
      <br />
      <span class="text-sm text-gray-500 italic">
        {concert.data.venue.city}, {concert.data.venue.country}
      </span>
    </td>
    <td class="border-b border-gray-200 px-4 py-2">
      <button
        type="button"
        class="rounded bg-gray-100 px-3 py-1 text-sm text-gray-700 transition hover:bg-gray-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-600"
        data-setlist-toggle={index}
        aria-controls={`setlist-${index}`}
        aria-expanded="false">
        View setlist
      </button>
    </td>
  </tr>
  <tr>
    <td colspan="4" class="bg-gray-50 p-0">
      <div
        id={`setlist-${index}`}
        aria-label="Concert setlist"
        class="overflow-hidden transition-all duration-800 ease-in-out"
        style="max-height: 0;">
        <ul class="w-full px-8 py-4 text-base text-gray-600" aria-label="Setlist songs">
          {
            concert.data.songs &&
              concert.data.songs.map((song) => (
                <Song order={song.order} title={song.title} />
              ))
          }
        </ul>
      </div>
    </td>
  </tr>
</>

<script is:inline define:vars={{ index }}>
  const btn = document.querySelector(`[data-setlist-toggle="${index}"]`);
  const row = document.getElementById(`setlist-${index}`);

  btn?.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', !isOpen);

    // Wait for next frame to ensure content is rendered
    requestAnimationFrame(() => {
      if (isOpen) {
        row.style.maxHeight = '0';
      } else {
        row.style.maxHeight = row.scrollHeight + 'px';
      }
    });

    btn.textContent = isOpen ? 'View setlist' : 'Hide setlist';
  });
</script>
