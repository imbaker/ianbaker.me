---
import FormattedDate from './FormattedDate.astro';
import type { Concert } from '../types/concert';

export interface Props {
  concert: Concert;
  index: number;
}

const { concert, index } = Astro.props;
---

<>
  <tr class="transition hover:bg-gray-50">
    <td
      class="border-b border-gray-200 bg-gray-500 px-4 py-2 text-center font-mono text-3xl tracking-tight text-gray-50">
      {index + 1}
    </td>
    <td class="border-b border-gray-200 px-4 py-2 text-gray-700">
      <FormattedDate date={concert.data.date} />
    </td>
    <td class="border-b border-gray-200 px-4 py-2 text-gray-700">
      <span>{concert.data.venue.name.replace("'", '’')}</span>
      <br />
      <span class="text-sm text-gray-500 italic">
        {concert.data.venue.city}, {concert.data.venue.country}
      </span>
    </td>
    <td class="border-b border-gray-200 px-4 py-2">
      <button
        type="button"
        onclick={`
          const row = document.getElementById('setlist-row-${index}');
          const section = row.querySelector('section');
          const btn = this;
          if (section.style.height === '' || section.style.height === '0px' || section.style.height === '0') {
            section.style.height = section.scrollHeight + 'px';
            btn.setAttribute('aria-expanded', 'true');
            btn.textContent = 'Hide';
          } else {
            section.style.height = '0';
            btn.setAttribute('aria-expanded', 'false');
            btn.textContent = 'View';
          }
        `}
        class="w-16 rounded bg-gray-100 px-3 py-1 text-sm text-gray-700 transition hover:bg-gray-200 hover:font-bold"
        aria-controls={`setlist-row-${index}`}
        aria-expanded="false">
        View
      </button>
    </td>
  </tr>
  <tr id={`setlist-row-${index}`}>
    <td colspan="4" class="bg-gray-50 p-0">
      <section aria-label="setlist" class="overflow-hidden transition-all duration-1000 ease-in-out" style="height:0;">
        <ul class="w-full px-8 py-4 text-base text-gray-600">
          {
            concert.data.songs &&
              concert.data.songs.map((song: { title: string }, index: number) => (
                <li class="mb-1">
                  <span class="font-mono text-gray-500">{index + 1}.</span>{' '}
                  {song.title.replace("'", '’')}
                </li>
              ))
          }
        </ul>
      </section>
    </td>
  </tr>
</>
