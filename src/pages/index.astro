---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Concert from '../components/Concert.astro';

const concerts = await getCollection('concerts');
concerts.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
---

<Layout>
  <div>
    <table class="table-auto border border-gray-200 bg-white">
      <thead>
        <tr class="bg-gray-50">
          <th class="border-gray-200 px-4 py-2 text-center font-bold text-gray-700"
            >#</th
          >
          <th class="border-gray-200 px-4 py-2 text-left font-bold text-gray-700"
            >Date</th
          >
          <th class="border-gray-200 px-4 py-2 text-left font-bold text-gray-700"
            >Venue</th
          >
          <th class="border-gray-200 px-4 py-2 text-center font-bold text-gray-700"
            >Setlist</th
          >
        </tr>
      </thead>
      <tbody>
        {
          concerts.map((concert, index) => (
            <Concert concert={concert} index={index} />
          ))
        }
      </tbody>
    </table>
  </div>
</Layout>
